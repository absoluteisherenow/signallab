# Example environment variables
# Copy to .env.local and fill in actual values

NEXT_PUBLIC_APP_NAME=Night Manoeuvres
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Analytics, API keys, etc.
# NEXT_PUBLIC_ANALYTICS_ID=
# API_SECRET_KEY=

# Twilio SMS — for text notifications + approval flows
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+44...
ARTIST_PHONE=+44...
