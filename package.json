{
  "name": "signal-lab-dashboard",
  "version": "1.0.0",
  "description": "Signal Lab Dashboard - Night Manoeuvres Edition",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "check:outbound": "bash scripts/check-outbound-gated.sh",
    "check:brain": "bash scripts/check-brain-wired.sh",
    "prebuild": "npm run check:outbound && npm run check:brain && node scripts/generate-sw.mjs",
    "build": "next build",
    "postbuild": "rm -f .next/server/pages/*.html",
    "build:worker": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion",
    "deploy": "npm run build && npm run build:worker && wrangler deploy",
    "start": "next start",
    "lint": "next lint",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "TAURI_BUILD=1 APPLE_KEYCHAIN_PROFILE=signallab-notary tauri build"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@opennextjs/cloudflare": "^1.19.1",
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "clsx": "^2.0.0",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.294.0",
    "next": "^14.0.0",
    "passkit-generator": "^3.5.7",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "resend": "^6.9.4",
    "sharp": "^0.34.5",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@cloudflare/workers-types": "^4.20260414.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "pg": "^8.20.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.3",
    "wrangler": "^4.82.2"
  }
}
